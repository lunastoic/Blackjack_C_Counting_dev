{
  "expo": {
    "name": "Blackjack Card Counter",
    "slug": "Blackjack_C_Counting",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/branding/app-icon.png",
    "scheme": "blackjackccounting",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#120607",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.lunastoic.blackjackcardcounter",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.lunastoic.blackjackcardcounter",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#120607",
        "foregroundImage": "./assets/branding/app-icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      "expo-router",
      "expo-audio",
      "expo-asset",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#120607",
          "image": "./assets/branding/app-icon.png",
          "imageWidth": 120
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
